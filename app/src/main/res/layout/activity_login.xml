<?xml version="1.0" encoding="utf-8"?>
<!-- activity_login.xml - تصميم شاشة تسجيل الدخول -->
<!-- مسار الملف: res/layout/activity_login.xml -->

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- مسافة علوية -->
        <View android:layout_width="0dp" android:layout_height="60dp"/>

        <!-- أيقونة -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏥"
            android:textSize="64sp"
            android:layout_marginBottom="16dp"/>

        <!-- عنوان -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تسجيل الدخول"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:layout_marginBottom="32dp"/>

        <!-- حقل البريد الإلكتروني -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="البريد الإلكتروني"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="16dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textEmailAddress"
                android:gravity="end"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- حقل كلمة المرور -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="كلمة المرور"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:passwordToggleEnabled="true"
            android:layout_marginBottom="24dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword"
                android:gravity="end"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- زر تسجيل الدخول -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="تسجيل الدخول"
            android:textSize="16sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- دائرة التحميل - مخفية في البداية -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- رابط إنشاء حساب جديد -->
        <TextView
            android:id="@+id/tvGoRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ليس لديك حساب؟ إنشاء حساب جديد"
            android:textColor="#1565C0"
            android:textSize="14sp"
            android:padding="8dp"/>

    </LinearLayout>
</ScrollView>
