<?xml version="1.0" encoding="utf-8"?>
<!-- item_appointment.xml - شكل كل بطاقة موعد -->
<!-- مسار الملف: res/layout/item_appointment.xml -->

<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- اسم الطبيب -->
        <TextView
            android:id="@+id/tvDoctorName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="د. محمد أحمد"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="4dp"/>

        <!-- التخصص -->
        <TextView
            android:id="@+id/tvSpecialty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="طب عام"
            android:textSize="14sp"
            android:textColor="#1565C0"
            android:layout_marginBottom="8dp"/>

        <!-- التاريخ والوقت -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 2025-03-15  ⏰ 10:00"
            android:textSize="14sp"
            android:textColor="#444444"
            android:layout_marginBottom="8dp"/>

        <!-- فاصل -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="8dp"/>

        <!-- الحالة وزر الإلغاء في صف واحد -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- حالة الموعد -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏳ قيد الانتظار"
                android:textSize="15sp"
                android:textStyle="bold"/>

            <!-- زر الإلغاء -->
            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="إلغاء ❌"
                android:textSize="12sp"
                android:backgroundTint="#FFEBEE"
                android:textColor="#C62828"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
