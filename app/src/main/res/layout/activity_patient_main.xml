<?xml version="1.0" encoding="utf-8"?>
<!-- activity_patient_main.xml - الشاشة الرئيسية للمريض -->
<!-- مسار الملف: res/layout/activity_patient_main.xml -->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header أزرق -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1565C0"
        android:padding="20dp"
        android:orientation="vertical">

        <!-- رسالة الترحيب -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="أهلاً 👋"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اختر طبيبك واحجز موعدك"
            android:textColor="#B3E5FC"
            android:textSize="14sp"/>

    </LinearLayout>

    <!-- شريط الأزرار -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <Button
            android:id="@+id/btnMyAppointments"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="📅 مواعيدي"
            android:textSize="13sp"
            android:backgroundTint="#E3F2FD"
            android:textColor="#1565C0"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="خروج 🚪"
            android:textSize="13sp"
            android:backgroundTint="#FFEBEE"
            android:textColor="#C62828"/>

    </LinearLayout>

    <!-- عنوان قائمة الأطباء -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="الأطباء المتاحون"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:padding="16dp"/>

    <!-- دائرة التحميل -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <!-- رسالة لا يوجد أطباء -->
    <TextView
        android:id="@+id/tvNoData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="لا يوجد أطباء حالياً"
        android:textSize="16sp"
        android:textColor="#999999"
        android:gravity="center"
        android:padding="40dp"
        android:visibility="gone"/>

    <!-- قائمة الأطباء -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

</LinearLayout>
