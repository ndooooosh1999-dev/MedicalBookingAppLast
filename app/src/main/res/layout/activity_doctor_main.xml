<?xml version="1.0" encoding="utf-8"?>
<!-- activity_doctor_main.xml - لوحة تحكم الطبيب -->
<!-- مسار الملف: res/layout/activity_doctor_main.xml -->

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header أخضر للطبيب -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1B5E20"
        android:padding="20dp"
        android:orientation="vertical">

        <!-- اسم الطبيب والتخصص -->
        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="د. محمد أحمد"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <!-- الإحصائيات السريعة -->
        <TextView
            android:id="@+id/tvStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ قيد الانتظار: 0   ✅ مؤكدة: 0"
            android:textColor="#C8E6C9"
            android:textSize="13sp"/>

    </LinearLayout>

    <!-- شريط الأزرار -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="طلبات المواعيد"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:gravity="center_vertical"/>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="خروج 🚪"
            android:textSize="13sp"
            android:backgroundTint="#FFEBEE"
            android:textColor="#C62828"/>

    </LinearLayout>

    <!-- دائرة التحميل -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"
        android:layout_marginTop="40dp"/>

    <!-- رسالة لا يوجد مواعيد -->
    <TextView
        android:id="@+id/tvNoData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="لا يوجد مواعيد حالياً 📭"
        android:textSize="16sp"
        android:textColor="#999999"
        android:gravity="center"
        android:padding="60dp"
        android:visibility="gone"/>

    <!-- قائمة المواعيد -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

</LinearLayout>
